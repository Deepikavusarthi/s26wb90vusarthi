extends layout

block content
  h1= title

  - let image_names = ['img1.jpg', 'img2.jpg', 'img3.jpg', 'img4.jpg', 'img5.jpg']

  - for (let i = 0; i < 3; i++) {
    - let index = Math.floor(Math.random() * 5)
    - let name = image_names[index]

    img(src=`/images/${name}` alt=`${name}` width="300" height="300")
  - }