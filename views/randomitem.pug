extends layout

block content
  h1= title

  - let image_names = ['zoo1.png', 'zoo2.png', 'zoo3.png', 'zoo4.png', 'zoo5.png']

  - for (let i = 0; i < 3; i++) {
    - let index = Math.floor(Math.random() * 5)
    - let name = image_names[index]

    img(src=`/images/${name}` alt=`${name}` width="300" height="300")
  - }