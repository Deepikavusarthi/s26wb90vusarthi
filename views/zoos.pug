extends layout

block content
  h1= title

  -
    let results = [
      { name: "San Diego Zoo", city: "San Diego", animals: 12000 },
      { name: "Bronx Zoo", city: "New York", animals: 6000 },
      { name: "London Zoo", city: "London", animals: 20000 }
    ]

  .container-fluid
    .row
      each item, index in results
        .col-sm-2
          div(onclick=`buy(${index})`, style="cursor: pointer; border: 1px solid #ccc; padding: 10px; margin: 5px;")
            p Name: #{item.name}
            p City: #{item.city}
            p Animals: #{item.animals}

  script.
    function buy(index) {
      alert(`You purchased item ${index}.`);
    }